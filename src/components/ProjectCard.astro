---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

const { entry } = Astro.props as { entry: CollectionEntry<"projects"> };
const { title, description, tech, github, demo, image, featured } = entry.data;
---

<article
  class="bg-surface rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border flex flex-col h-full"
>
  {
    image && (
      <div class="aspect-video w-full overflow-hidden">
        <Image
          src={image}
          alt={title}
          width={600}
          height={315}
          class="object-cover w-full h-full hover:scale-105 transition-transform duration-300"
        />
      </div>
    )
  }

  <div class="p-6 flex flex-col flex-grow">
    {
      (tech.length > 0 || featured) && (
        <div class="flex flex-wrap gap-2 mb-3">
          {featured && (
            <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-primary text-primary-foreground">
              Featured
            </span>
          )}
          {tech.map((t) => (
            <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-pill text-pill-foreground">
              {t}
            </span>
          ))}
        </div>
      )
    }

    <h3 class="text-xl font-bold text-foreground mb-2 leading-tight">
      <a href={`/projects/${entry.id}`} class="hover:underline">{title}</a>
    </h3>

    <p class="text-muted text-sm mb-4 line-clamp-3 flex-grow">
      {description}
    </p>

    {
      (github || demo) && (
        <div class="mt-auto pt-4 border-t border-border flex items-center gap-4 text-xs font-medium text-muted-subtle">
          {github && (
            <a href={github} target="_blank" rel="noopener" class="hover:text-primary">
              GitHub
            </a>
          )}
          {demo && (
            <a href={demo} target="_blank" rel="noopener" class="hover:text-primary">
              Live Demo
            </a>
          )}
        </div>
      )
    }
  </div>
</article>
