---
const currentYear = new Date().getFullYear();
const github = "https://github.com/KennethOng02";
const linkedin = "https://www.linkedin.com/in/kenneth-kuan-phing-ong-5b31322b8/";
---

<div class="border-t border-border bg-surface">
  <div
    class="mx-auto flex max-w-5xl flex-col-reverse items-center gap-3 px-6 py-6 text-sm sm:flex-row sm:justify-between"
  >
    <p class="font-mono text-xs text-muted-subtle">&copy; {currentYear} Kenneth Ong</p>

    <div class="flex items-center gap-5">
      <a href="/contact" class="text-muted transition-colors hover:text-primary">Get in touch →</a>

      <a
        href={github}
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub"
        class="text-muted transition-colors hover:text-primary"
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>

      <a
        href={linkedin}
        target="_blank"
        rel="noreferrer"
        aria-label="LinkedIn"
        class="text-muted transition-colors hover:text-primary"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.38 4.28 5.47v6.27zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</div>
