---
import { Image } from "astro:assets";

const { title, description, pubDate, url, image, tags } = Astro.props;
---

<article
  class="bg-white dark:bg-slate-800 rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-slate-100 dark:border-slate-700 flex flex-col h-full"
>
  {
    image && (
      <div class="aspect-video w-full overflow-hidden">
        <Image
          src={image.src}
          alt={image.alt}
          width={600}
          height={315}
          class="object-cover w-full h-full hover:scale-105 transition-transform duration-300"
        />
      </div>
    )
  }

  <div class="p-6 flex flex-col flex-grow">
    {
      tags && (
        <div class="flex flex-wrap gap-2 mb-3">
          {tags.map((tag: string) => (
            <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    <h3
      class="text-xl font-bold text-slate-900 dark:text-white mb-2 leading-tight"
    >
      <a href={url} class="hover:underline">{title}</a>
    </h3>

    <p
      class="text-slate-600 dark:text-slate-400 text-sm mb-4 line-clamp-3 flex-grow"
    >
      {description}
    </p>

    <div
      class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-700 flex items-center text-xs text-slate-500 dark:text-slate-400"
    >
      <time datetime={pubDate}>
        {
          new Date(pubDate).toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
    </div>
  </div>
</article>
