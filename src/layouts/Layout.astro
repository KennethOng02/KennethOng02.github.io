---
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource-variable/inter";
import "../styles/global.css";

const { title, description, wide = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Kenneth Ong</title>
  </head>

  <body class="flex flex-col min-h-screen font-sans">
    <header>
      <NavBar />
    </header>

    {
      wide ? (
        <main class="grow">
          <slot />
        </main>
      ) : (
        <main class="grow p-8">
          {title && <h1 class="text-3xl font-bold font-display capitalize">{title}</h1>}
          {description && <h2 class="text-2xl font-semibold text-muted">{description}</h2>}
          <slot />
        </main>
      )
    }

    <footer>
      <Footer />
    </footer>
  </body>
</html>
